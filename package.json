    "@wooksjs/event-wf": "^0.4.13",
    "@wooksjs/http-body": "^0.4.13",
    "conventional-changelog": "^5.1.0",
    "conventional-changelog-cli": "^4.1.0",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitepress": "^1.0.0-beta.1",
