{
  "name": "@aoothjs/user-as",
  "version": "0.0.1-alpha.6",
  "description": "UsersStore backed by @atscript/db",
  "keywords": [
    "aoothjs",
    "atscript",
    "auth",
    "database",
    "users-store"
  ],
  "homepage": "https://github.com/aoothjs/aoothjs/tree/main/packages/user-as#readme",
  "bugs": {
    "url": "https://github.com/aoothjs/aoothjs/issues"
  },
  "license": "MIT",
  "author": "Artem Maltsev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aoothjs/aoothjs.git",
    "directory": "packages/user-as"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./models": {
      "types": "./dist/models/user.as.d.ts",
      "import": "./dist/models/user.as.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "asc -f dts",
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@aoothjs/user": "workspace:*"
  },
  "devDependencies": {
    "@atscript/core": "^0.1.41",
    "@atscript/db": "^0.1.42",
    "@atscript/db-sqlite": "^0.1.42",
    "@atscript/typescript": "^0.1.41",
    "@types/better-sqlite3": "^7.6.13",
    "@uniqu/core": "^0.1.2",
    "better-sqlite3": "^12.6.2",
    "unplugin-atscript": "^0.1.39"
  },
  "peerDependencies": {
    "@atscript/db": ">=0.1.42"
  }
}
